{
  "sinsal_rules": {
    "12_sinsal": {
      "desc": "년지 또는 일지 기준으로 나머지 지지와의 관계",
      "mapping": {
        "신자진": {"해":"겁살", "자":"재살", "축":"천살", "인":"지살", "묘":"연살", "진":"월살", "사":"망신", "오":"장성", "미":"반안", "신":"역마", "유":"육해", "술":"화개"},
        "인오술": {"해":"지살", "자":"연살", "축":"월살", "인":"망신", "묘":"장성", "진":"반안", "사":"역마", "오":"육해", "미":"화개", "신":"겁살", "유":"재살", "술":"천살"},
        "사유축": {"해":"역마", "자":"육해", "축":"화개", "인":"겁살", "묘":"재살", "진":"천살", "사":"지살", "오":"연살", "미":"월살", "신":"망신", "유":"장성", "술":"반안"},
        "해묘미": {"해":"망신", "자":"장성", "축":"반안", "인":"역마", "묘":"육해", "진":"화개", "사":"겁살", "오":"재살", "미":"천살", "신":"지살", "유":"연살", "술":"월살"}
      }
    },
    "major_stars": {
      "천을귀인": {"standard": "일간", "map": {"갑": ["축", "미"], "을": ["자", "신"], "병": ["해", "유"], "정": ["해", "유"], "무": ["축", "미"], "기": ["자", "신"], "경": ["축", "미"], "신": ["인", "오"], "임": ["묘", "사"], "계": ["묘", "사"]}},
      "문창귀인": {"standard": "일간", "map": {"갑": "사", "을": "오", "병": "신", "정": "유", "무": "신", "기": "유", "경": "해", "신": "자", "임": "인", "계": "묘"}},
      "백호살": {"standard": "간지", "list": ["갑진", "을미", "병술", "정축", "무진", "임술", "계축"]},
      "괴강살": {"standard": "간지", "list": ["무술", "경술", "경진", "임진"]},
      "귀문관살": {"standard": "지지조합", "list": ["자유", "축오", "인미", "묘신", "진해", "사술"]}
    }
  },
  "interpretations": {
    "역마살": "이동과 변화의 기운. 현대에는 글로벌 비즈니스나 활동적인 직업운으로 해석합니다.",
    "도화살(연살)": "타인의 시선을 끄는 매력. 예술, 연예, 서비스업에서 강력한 무기가 됩니다.",
    "화개살": "예술적 감수성과 종교적 성향. 학문이나 예술 분야에서 깊은 성취를 이룹니다.",
    "천을귀인": "인생 최 최고의 길신. 큰 어려움이 닥쳐도 반드시 돕는 손길이 나타납니다.",
    "문창귀인": "총명한 두뇌와 문필력. 공부와 연구, 기획 분야에서 두각을 나타냅니다.",
    "백호살": "강한 추진력과 폭발적인 에너지. 전문직에서 성공할 확률이 높으나 건강과 사고를 주의해야 합니다.",
    "귀문관살": "천재적인 직관력과 예민함. 예술가나 종교인, 전문 기술직에게서 많이 보입니다."
  }
}